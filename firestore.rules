rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Assets
    match /assets/{assetId} {
      // Any authenticated user can read (for shared registry view)
      allow read: if request.auth != null;

      // Owner has full write access
      allow write: if request.auth != null
                   && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;

      // Beneficiaries can express interest — allowed to update ONLY the interestedParties field
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['interestedParties']);
    }

    // Invites
    match /invites/{inviteId} {
      // Registry owner can create invites
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.registryOwnerUid;

      // Owner reads/updates/deletes their own invites; invited person reads theirs
      allow read: if request.auth != null && (
                    request.auth.uid == resource.data.registryOwnerUid ||
                    request.auth.token.email == resource.data.invitedEmail
                  );
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.registryOwnerUid;
    }

    // User settings: documents use auto-generated IDs with a uid field,
    // so we check the uid field in the document data rather than the doc ID.
    match /userSettings/{settingsId} {
      // Read and update existing documents
      allow read, update, delete: if request.auth != null
                                  && resource.data.uid == request.auth.uid;
      // Create a new settings document (doc doesn't exist yet, use request.resource)
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
