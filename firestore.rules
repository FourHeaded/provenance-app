rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin access ───────────────────────────────────────────────
    // Replace ADMIN_UID below with your Firebase Auth UID.
    // This must match src/admin.js
    function isAdmin() {
      return request.auth != null
             && request.auth.uid == '6Oqu1jFasvYOKauEqotgCMeQH7o1';
    }

    // ── Invite check ───────────────────────────────────────────────
    // Returns true if the current user has a non-declined invite from
    // the given owner. Relies on deterministic invite document IDs of
    // the form `{registryOwnerUid}_{lowercased invitedEmail}`.
    function hasValidInvite(ownerUid) {
      let inviteId = ownerUid + '_' + request.auth.token.email;
      return exists(/databases/$(database)/documents/invites/$(inviteId)) &&
        get(/databases/$(database)/documents/invites/$(inviteId)).data.status != 'declined';
    }

    // Assets
    match /assets/{assetId} {
      // Admin: full read access for the dashboard
      allow read: if isAdmin();

      // Owner OR a beneficiary with a valid (non-declined) invite from the owner
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.uid
                      || hasValidInvite(resource.data.uid));

      // Owner has full write access
      allow write: if (request.auth != null
                       && request.auth.uid == resource.data.uid)
                   || isAdmin();
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;

      // Beneficiaries can express interest — allowed to update ONLY the interestedParties field
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['interestedParties']);
    }

    // Invites
    match /invites/{inviteId} {
      // Admin: full read access
      allow read: if isAdmin();

      // Registry owner can create invites
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.registryOwnerUid;

      // Owner reads/updates/deletes their own invites; invited person reads theirs
      allow read: if request.auth != null && (
                    request.auth.uid == resource.data.registryOwnerUid ||
                    request.auth.token.email == resource.data.invitedEmail
                  );
      allow update, delete: if (request.auth != null
                                && request.auth.uid == resource.data.registryOwnerUid)
                            || isAdmin();
    }

    // User settings: documents use auto-generated IDs with a uid field,
    // so we check the uid field in the document data rather than the doc ID.
    match /userSettings/{settingsId} {
      // Admin: read all + update isPremium on any user
      allow read, update: if isAdmin();

      // Read and update existing documents
      allow read, update, delete: if (request.auth != null
                                      && resource.data.uid == request.auth.uid)
                                  || isAdmin();
      // Create a new settings document (doc doesn't exist yet, use request.resource)
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
    }

    // Estate planning documents
    match /estateDocs/{docId} {
      // Owner: full access
      allow read, delete: if (request.auth != null
                              && resource.data.uid == request.auth.uid)
                          || isAdmin();
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;

      // Beneficiaries: read if their email is in sharedWith,
      // or if the doc is shared with everyone via the '__all__' token
      allow read: if request.auth != null && (
                    request.auth.token.email in resource.data.get('sharedWith', []) ||
                    '__all__' in resource.data.get('sharedWith', [])
                  );
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
